! =====================================================
!  VPN SITE-TO-SITE BASADA EN ENRUTAMIENTO (VTI) - IKEv2
! =====================================================

! ---------- R1 ----------
hostname R1
!
interface Ethernet0/0
 ip address 100.1.1.1 255.255.255.252
 no shutdown
!
interface Ethernet0/1
 ip address 6.6.1.1 255.255.255.0
 no shutdown
!
! --- IKEv2 ---
crypto ikev2 proposal PROP
 encryption aes-cbc-256
 integrity sha256
 group 14
!
crypto ikev2 policy POL
 proposal PROP
!
crypto ikev2 keyring KR
 peer R2
  address 100.2.2.2
  pre-shared-key Cisco123
!
crypto ikev2 profile PROF
 match identity remote address 100.2.2.2 255.255.255.255
 authentication remote pre-share
 authentication local pre-share
 keyring local KR
!
! --- IPSec + perfil para el tunel ---
crypto ipsec transform-set TSET esp-aes 256 esp-sha-hmac
 mode tunnel
!
crypto ipsec profile IPROF
 set transform-set TSET
 set ikev2-profile PROF
!
! --- Interfaz de tunel (VTI) ---
interface Tunnel0
 ip address 172.16.0.1 255.255.255.252
 tunnel source Ethernet0/0
 tunnel destination 100.2.2.2
 tunnel mode ipsec ipv4
 tunnel protection ipsec profile IPROF
!
ip route 0.0.0.0 0.0.0.0 100.1.1.2
ip route 6.6.2.0 255.255.255.0 172.16.0.2
!

! ---------- ISP ----------
hostname ISP
!
interface Ethernet0/0
 ip address 100.1.1.2 255.255.255.252
 no shutdown
!
interface Ethernet0/1
 ip address 100.2.2.1 255.255.255.252
 no shutdown
!

! ---------- R2 ----------
hostname R2
!
interface Ethernet0/0
 ip address 100.2.2.2 255.255.255.252
 no shutdown
!
interface Ethernet0/1
 ip address 6.6.2.1 255.255.255.0
 no shutdown
!
crypto ikev2 proposal PROP
 encryption aes-cbc-256
 integrity sha256
 group 14
!
crypto ikev2 policy POL
 proposal PROP
!
crypto ikev2 keyring KR
 peer R1
  address 100.1.1.1
  pre-shared-key Cisco123
!
crypto ikev2 profile PROF
 match identity remote address 100.1.1.1 255.255.255.255
 authentication remote pre-share
 authentication local pre-share
 keyring local KR
!
crypto ipsec transform-set TSET esp-aes 256 esp-sha-hmac
 mode tunnel
!
crypto ipsec profile IPROF
 set transform-set TSET
 set ikev2-profile PROF
!
interface Tunnel0
 ip address 172.16.0.2 255.255.255.252
 tunnel source Ethernet0/0
 tunnel destination 100.1.1.1
 tunnel mode ipsec ipv4
 tunnel protection ipsec profile IPROF
!
ip route 0.0.0.0 0.0.0.0 100.2.2.1
ip route 6.6.1.0 255.255.255.0 172.16.0.1
!

! ---------- PCs ----------
! PC-1>  ip 6.6.1.10 255.255.255.0 6.6.1.1
! PC-2>  ip 6.6.2.10 255.255.255.0 6.6.2.1
